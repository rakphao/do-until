{
  "description": "do-until execution loop Stop hook",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/scripts/run.mjs\" stop",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/run.mjs\" stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}